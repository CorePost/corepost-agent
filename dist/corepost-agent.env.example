# Optional environment file for corepost-agent.service.
#
# This file is typically installed as /etc/corepost-agent.env (0600).
# Values here are examples; keep secrets protected.

COREPOST_SERVER_URL="__SET_ME__"
COREPOST_DEVICE_ID="__SET_ME__"
COREPOST_DEVICE_SECRET="__SET_ME__"

# Optional tuning.
# COREPOST_AGENT_POLL_INTERVAL_SECONDS=""
# COREPOST_AGENT_HEARTBEAT_SECONDS=""  # deprecated alias for COREPOST_AGENT_POLL_INTERVAL_SECONDS
# COREPOST_AGENT_MIN_POLL_SECONDS="2"
# COREPOST_AGENT_MAX_POLL_SECONDS="300"
# COREPOST_AGENT_ACK_OBSERVE_EVERY_SECONDS="60"
# COREPOST_AGENT_CONNECT_TIMEOUT_SECONDS="5"
# COREPOST_AGENT_MAX_TIME_SECONDS="20"
# COREPOST_AGENT_BACKOFF_MAX_SECONDS="60"
# COREPOST_AGENT_STATE_DIR="/var/lib/corepost-agent"

# Dangerous action gate: the server may request "shutdown" when the device is locked.
# Leave disabled for demos unless you explicitly want the machine to power off.
# COREPOST_AGENT_ENABLE_SHUTDOWN="0"
# COREPOST_AGENT_SHUTDOWN_DELAY_SECONDS="10"
